{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/joggrdocs/home/refs/heads/main/schema.json",
  "title": "Joggr Configuration",
  "description": "Configuration for Joggr CLI and tools in jog.config.{ts,mts,json,jsonc,yaml} files.",
  "type": "object",
  "properties": {
    "sandbox": {
      "type": "object",
      "properties": {
        "local": {
          "type": "object",
          "properties": {
            "copy": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Glob patterns for files/directories to copy to new worktrees."
            },
            "run": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Commands to run in order after worktree creation."
            },
            "command": {
              "type": "string",
              "description": "Command to launch after sandbox setup completes (e.g. \"claude\", \"code .\", \"zsh\")."
            }
          },
          "additionalProperties": false,
          "description": "Local git-worktree sandbox configuration."
        }
      },
      "additionalProperties": false,
      "description": "Sandbox environment configuration."
    },
    "notify": {
      "type": "object",
      "properties": {
        "sounds": {
          "default": [
            "chime"
          ],
          "description": "Sounds to play when the agent stops — picks one at random.",
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "afrobeats",
              "barbershop",
              "country",
              "drill",
              "edm",
              "folk",
              "metal",
              "reggae",
              "ping",
              "chime",
              "success-ding",
              "victory",
              "achievement",
              "fanfare",
              "rush"
            ]
          }
        },
        "enable": {
          "default": true,
          "description": "Enable or disable sound notifications.",
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "description": "Notification sound configuration."
    },
    "hooks": {
      "type": "object",
      "properties": {
        "plan_review": {
          "default": true,
          "description": "Enable the plan review hook — opens a browser UI for reviewing AI plans before they execute.",
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "description": "Hook feature toggles."
    }
  },
  "additionalProperties": false
}
