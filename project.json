{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "project": {
    "owner": "joggrdocs",
    "number": 9,
    "title": "roadmap",
    "description": "The public hub for Joggr — documentation, roadmap, and community.",
    "visibility": "PRIVATE",
    "readme": ""
  },
  "fields": [
    {
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        {
          "name": "Idea",
          "description": "Raw idea or suggestion",
          "color": "PURPLE"
        },
        {
          "name": "Planned",
          "description": "Planned feature",
          "color": "YELLOW"
        },
        {
          "name": "In progress",
          "description": "Approved and actively being worked on",
          "color": "BLUE"
        },
        {
          "name": "Released",
          "description": "Released feature",
          "color": "GREEN"
        }
      ]
    },
    {
      "name": "Start date",
      "type": "DATE"
    },
    {
      "name": "Target date",
      "type": "DATE"
    }
  ],
  "views": [
    {
      "name": "Board",
      "layout": "BOARD",
      "groupBy": "Status",
      "sortBy": null,
      "fields": [
        "Title",
        "Status",
        "Assignees",
        "Labels"
      ]
    },
    {
      "name": "Backlog",
      "layout": "TABLE",
      "groupBy": null,
      "sortBy": {
        "field": "Status",
        "direction": "ASC"
      },
      "fields": [
        "Title",
        "Status",
        "Assignees",
        "Labels"
      ],
      "filter": "status:Todo,\"In progress\""
    }
  ],
  "statusMapping": {
    "Idea": "Idea",
    "Planned": "Todo",
    "Approved": "In progress",
    "Released": "Done"
  }
}